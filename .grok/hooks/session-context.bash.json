{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .grok/hooks/scripts/invoke-hook.sh session-start-marker",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .grok/hooks/scripts/invoke-hook.sh session-end-update-context",
            "timeout": 180
          }
        ]
      }
    ]
  }
}