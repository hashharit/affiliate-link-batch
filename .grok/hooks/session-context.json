{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .grok/hooks/scripts/session-start-marker.ps1",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .grok/hooks/scripts/session-end-update-context.ps1",
            "timeout": 180
          }
        ]
      }
    ]
  }
}